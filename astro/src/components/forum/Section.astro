---
import ForumHeader from "@/components/forum/common/Header.astro";
import OkpTopicCard from "@/components/forum/TopicCard.astro";
import OkpTopicsList from "@/components/forum/react/TopicsList.jsx";
import Loading from "@/components/common/Loading.astro";

const { slug } = Astro.params;
const { section } = Astro.props;
---

<article class="okp-forum-section">
  <ForumHeader title={section.name} description={section.description} />
  <OkpTopicsList slug={slug} section={section} client:only="react">
    <Loading slot="fallback" />
  </OkpTopicsList>
</article>
