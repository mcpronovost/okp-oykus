---
import type { SectionTopic } from "@/types/forums.types";
import { Image } from "astro:assets";
import { CircleArrowOutDownRight, Clock, MessagesSquare } from "lucide-astro";
import { qpdate, qpunit } from "@mcpronovost/qpfilters";
import imgAvatar from "@/assets/img/mc.jpg";

interface Props {
  topic: SectionTopic;
  index: number;
  total: number;
}

const { topic, index, total }: Props = Astro.props;

const hasBasis = (
  (((total % 5) === 0) && index === 0) ? "100" :
  (((total % 6) === 0) && (index === 0 || index === 1)) ? "50" :
  (((total % 7) === 0) && (index === 0 || index === 1 || index === 2)) ? "33" : null
);
---

<article class={`okp-topics-card okp-animate-boxup ${hasBasis ? `okp-basis-${hasBasis}` : ""}`}>
  <section class="okp-topics-card-authors">
    <figure class="okp-topics-card-authors-banner">
      {true ? (
        <Image src={imgAvatar} alt="" class="okp-topics-card-authors-banner-img" />
      ) : (
        <span class="okp-topics-card-authors-banner-abbr">MC</span>
      )}
    </figure>
    <figure class="okp-topics-card-authors-avatar">
      <a href={`${topic.path}`} class="okp-topics-card-authors-linklastmessage">
        <CircleArrowOutDownRight size={32} alt="Aller au dernier message" class="okp-topics-card-authors-golastmessage" />
        {true ? (
          <Image src={imgAvatar} alt="" class="okp-topics-card-authors-avatar-img" aria-hidden="true" />
        ) : (
          <span class="okp-topics-card-authors-avatar-abbr" aria-hidden="true">MC</span>
        )}
      </a>
    </figure>
  </section>
  <header class="okp-topics-card-header">
    <div class="okp-topics-card-header-date">
      <span>31 octobre 2024</span>
    </div>
    <h3 class="okp-topics-card-header-title">
      <a href={`${topic.path}`}>{topic.name.length > 64 ? `${topic.name.substring(0, 64)}...` : topic.name}</a>
    </h3>
  </header>
  <footer class="okp-topics-card-footer">
    <time class="okp-topics-card-footer-date">
      <span class="okp-icon"><Clock size={12} /></span>
      <span class="okp-text">{
        qpdate(topic.last_message?.created_at || topic.created_at)
      }</span>
    </time>
    <div class="okp-topics-card-footer-total">
      <span class="okp-text">{qpunit(topic.total_messages)}</span>
      <span class="okp-icon"><MessagesSquare size={12} /></span>
    </div>
  </footer>
</article>
