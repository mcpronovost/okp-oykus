---
import SectionCard from "@/components/forum/SectionCard.astro";

const { slug } = Astro.params;
const { category, singleton } = Astro.props;
---

<article class="okp-categories-card">
  <header class="okp-categories-card-header">
    <h2 class="okp-categories-card-title">
        {singleton ? (
            <span>{category.name}</span>
        ) : (
            <a href={`/g/${slug}/c${category.id}-${category.slug}/`}>{category.name}</a>
        )}
    </h2>
    {category.description && (
        <p class="okp-categories-card-description">{category.description}</p>
    )}
  </header>
  <section class="okp-forum-sections">
    {(category.sections && category.sections.length) ? category.sections.map((item) => (
        <SectionCard section={item} />
    )) : (
        <div>-</div>
    )}
  </section>
</article>
