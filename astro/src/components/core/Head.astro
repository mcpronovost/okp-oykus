---
import { Image } from "astro:assets";
import { Bell, Mail, Smile } from "lucide-astro";
import OkpSideleftToggle from "@/components/core/react/SideleftToggle.jsx";
import imgLogo from "@/assets/img/oykus-32.png";
import imgAvatar from "@/assets/img/mc.jpg";
---

<header id="okp-core-head">
  <section class="okp-branding">
    <a href="/" class="okp-branding-link">
      <div class="okp-branding-logo">
        <Image src={imgLogo} alt="" width="32" height="32" loading="eager" />
      </div>
      <span class="okp-branding-name" itemprop="name">Oykus</span>
    </a>
  </section>
  <OkpSideleftToggle client:idle />
  <section class="okp-menu">
    <nav>
      <ul>
        <li>
          <a href="/">À propos</a>
        </li>
        <li>
          <a href="/">Cynorrs</a>
        </li>
        <li>
          <a href="/">FAQ</a>
        </li>
        <li>
          <a href="/">Politique de confidentialité</a>
        </li>
      </ul>
    </nav>
  </section>
  <section class="okp-space"></section>
  <section class="okp-notifications">
    <div class="okp-notifications-alerts">
      <div class="okp-wrapper">
        <div><Bell /></div>
      </div>
    </div>
    <div class="okp-notifications-privates">
      <div class="okp-wrapper">
        <div><Mail /></div>
      </div>
    </div>
    <div class="okp-notifications-friends">
      <div class="okp-wrapper">
        <div><Smile /></div>
      </div>
    </div>
  </section>
  <section class="okp-auth">
    <div class="okp-auth-user">
      <div class="okp-auth-user-playername">
        <span>M-C Pronovost</span>
      </div>
      <div class="okp-auth-user-avatar">
        <figure>
          <Image src={imgAvatar} alt="" width="32" height="32" />
        </figure>
      </div>
    </div>
  </section>
</header>
