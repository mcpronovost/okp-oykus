---
import "@/assets/styles/main.scss";
import CoreHead from "@/components/core/Head.astro";
import CoreSideleft from "@/components/core/Sideleft.astro";
import CoreSiderigh from "@/components/core/Siderigh.astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description || title} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="mcpronovost" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body id="okp" itemscope itemtype="https://schema.org/Game">
    <CoreHead />
    <div id="okp-core-body">
      <CoreSideleft />
      <main id="okp-core-main">
        <slot />
      </main>
      <CoreSiderigh />
    </div>
  </body>
</html>
