---
import "@/assets/styles/vendors/simplebar.scss";
import "@/assets/styles/main.scss";
import CoreHead from "@/components/core/Head.astro";
import CoreSideleft from "@/components/core/Sideleft.astro";
import CoreSiderigh from "@/components/core/Siderigh.astro";

const { title, description, theme } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}{title ? " - Oykus" : "Oykus"}</title>
    <meta name="description" content={description || title} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="mcpronovost" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="512x512"  href="/android-chrome-512x512.png">
    <link rel="icon" type="image/png" sizes="192x192"  href="/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <meta name="theme-color" content="#c9cfd1" /> 
  </head>
  <body id="okp" style={theme} itemscope itemtype="https://schema.org/Game">
    <CoreHead />
    <div id="okp-core-body">
      <CoreSideleft />
      <main id="okp-core-main" class="okp-scrollable">
        <slot />
      </main>
      <CoreSiderigh />
    </div>
  </body>
</html>

<script>
  import { SimpleBar } from "@/assets/scripts/vendors/simplebar.min.js";

  new SimpleBar(document.getElementById("okp-core-main"));
  new SimpleBar(document.getElementById("okp-core-siderigh"));
</script>
