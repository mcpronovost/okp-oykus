---
import type { Lang } from "@/types/i18n.types";
import type { CategorySection } from "@/types/forums.types";
import { CircleArrowOutDownRight } from "lucide-astro";
import { qpdate } from "@mcpronovost/qpfilters";
import { getTranslation } from "@/i18n/i18n";
import imgAvatar from "@/assets/img/mc.jpg";

interface Props {
  lang: Lang;
  section: CategorySection;
}

const { lang, section }: Props = Astro.props;
const t = getTranslation(lang);

console.log(">> section: ", section);
---

<article class={`okp-sections-card okp-basis-${section.basis}`}>
  <div class="okp-sections-card-wrapper okp-animate-boxup">
    {section.banner && (
      <section class="okp-sections-card-banner" style={`height: ${section.banner_height}px`}>
        <figure class="okp-sections-card-banner-figure">
          <img src={section.banner} alt="" class="okp-sections-card-banner-figure-img" aria-hidden="true" />
        </figure>
      </section>
    )}
    {(section.show_last_message && section.last_message) && (
      <section class={`okp-sections-card-lastmessage ${section.banner ? "okp-with-banner" : ""}`}>
        <figure class="okp-sections-card-lastmessage-avatar">
          <a href={`${section.last_message.path}?page=last`} class="okp-sections-card-lastmessage-link" aria-label={t("Go to the last message")} title={t("Go to the last message")}>
            <CircleArrowOutDownRight size={32} alt="Aller au dernier message" class="okp-sections-card-lastmessage-golast" />
            {true ? (
              <img src={imgAvatar.src} alt="" class="okp-sections-card-lastmessage-avatar-img" aria-hidden="true" />
            ) : (
              <span class="okp-sections-card-lastmessage-avatar-abbr" aria-hidden="true">MC</span>
            )}
          </a>
        </figure>
      </section>
    )}
    <header class="okp-sections-card-header">
      <h3 class="okp-sections-card-header-title">
        <a href={`${section.path}`}>{section.name.length > 64 ? `${section.name.substring(0, 64)}...` : section.name}</a>
      </h3>
    </header>
    {(section.show_last_topic && section.last_topic) && (
      <footer class="okp-sections-card-footer">
        <div class="okp-sections-card-footer-lastmessage">
          <a href={`${section.last_topic.path}`} aria-label={t("Go to the last topic")} title={t("Go to the last topic")}>
            {section.last_topic.name.length > 32 ? `${section.last_topic.name.substring(0, 32)}...` : section.last_topic.name}
          </a>
          <span>{qpdate(section.last_topic.created_at, lang)}</span>
        </div>
      </footer>
    )}
  </div>
</article>
