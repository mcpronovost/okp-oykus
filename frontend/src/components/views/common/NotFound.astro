---
import type { LangType } from "@/services/utils/types";
import { getTranslation } from "@/services/i18n";

const { lang } = Astro.params as { lang: LangType };
const { t } = getTranslation(lang);
---

<div class="okp-fullview">
    <div class="okp-error">
        <h1 class="okp-error-title">404</h1>
        <h2 class="okp-error-subtitle">{t("Oops! Page Not Found")}</h2>
        <p class="okp-error-message">
            {t("The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.")}
        </p>
        <a href={`/${lang}`} class="okp-btn okp-btn-error">{t("Go Back Home")}</a>
    </div>
</div>
