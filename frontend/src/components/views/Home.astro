---
import { Award } from "lucide";
import { Test1, Test2 } from "@/components/react/applications";
import OkpIcon from "@/components/common/Icon.astro";

const { lang } = Astro.params;
---

<h1 style="font-size: 12rem; word-spacing: 100vw;">Explore Build Survive</h1>

<p style="display: block;max-width: 25vw;">The only aim in Rust is to survive. Everything wants you to die - the island’s wildlife and other inhabitants, the environment, other survivors. Do whatever it takes to last another night.</p>

<p>aaa {lang}</p>

<div>
    <OkpIcon icon={Award} />
</div>

<Test2 client:only="react" />

<div style="background-color: var(--okp-card-bg); border-left: 2px solid var(--okp-error); color: var(--okp-card-fg);display: block; width: 500px; padding: 12px 24px; margin: 0 auto;">
    <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.</p>
</div>

<Test1 client:only="react" />

<div style="background-color: var(--okp-card-bg); border-left: 2px solid var(--okp-success); color: var(--okp-card-fg);display: block; width: 500px; padding: 12px 24px; margin: 0 auto;">
    <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.</p>
</div>

<div style="display: flex; flex-direction: row; gap: 12px; align-items: center; justify-content: center; margin: 32px auto;">
    <span style="background: color-mix(in srgb, var(--okp-tier1) 15%, var(--okp-card-bg)); border-left: 1px solid var(--okp-tier1); color: color-mix(in srgb, var(--okp-tier1) 50%, var(--okp-card-fg)); padding: 4px 12px;">Tier 1</span>
    <span style="background: color-mix(in srgb, var(--okp-tier2) 15%, var(--okp-card-bg)); border-left: 1px solid var(--okp-tier2); color: color-mix(in srgb, var(--okp-tier2) 50%, var(--okp-card-fg)); padding: 4px 12px;">
        <span>Tier 2</span>
    </span>
    <span style="background: color-mix(in srgb, var(--okp-tier3) 15%, var(--okp-card-bg)); border-left: 1px solid var(--okp-tier3); color: color-mix(in srgb, var(--okp-tier3) 50%, var(--okp-card-fg)); padding: 4px 12px;">Tier 3</span>
    <span style="background: color-mix(in srgb, var(--okp-tier4) 15%, var(--okp-card-bg)); border-left: 1px solid var(--okp-tier4); color: color-mix(in srgb, var(--okp-tier4) 50%, var(--okp-card-fg)); padding: 4px 12px;">Tier 4</span>
    <span style="background: color-mix(in srgb, var(--okp-tier5) 15%, var(--okp-card-bg)); border-left: 1px solid var(--okp-tier5); color: color-mix(in srgb, var(--okp-tier5) 50%, var(--okp-card-fg)); padding: 4px 12px;">Tier 5</span>
    <span style="background: color-mix(in srgb, var(--okp-tier6) 15%, var(--okp-card-bg)); border-left: 1px solid var(--okp-tier6); color: color-mix(in srgb, var(--okp-tier6) 50%, var(--okp-card-fg)); padding: 4px 12px;">Tier 6</span>
</div>
