---
interface Props {
  type: "success" | "error" | "warning";
}

const { type }: Props = Astro.props;
---
{(type === "success") ? (
  <div class="okp-svg-success okp-animate-svg">
    <svg class="okp-circular">
      <circle
        class="path"
        cx="75"
        cy="75"
        r="50"
        fill="none"
        stroke-width="5"
        stroke-miterlimit="10"></circle>
    </svg>
    <svg class="okp-checkmark">
      <g transform="matrix(0.79961,8.65821e-32,8.39584e-32,0.79961,-489.57,-205.679)">
        <path
          class="checkmark__check"
          fill="none"
          d="M616.306,283.025L634.087,300.805L673.361,261.53"></path>
      </g>
    </svg>
  </div>
) : (type === "error") ? (
  <div class="okp-svg-error okp-animate-svg">
    <svg class="okp-circular">
      <circle
        class="path"
        cx="75"
        cy="75"
        r="50"
        fill="none"
        stroke-width="5"
        stroke-miterlimit="10"></circle>
    </svg>
    <svg class="okp-cross">
      <g transform="matrix(0.79961,8.65821e-32,8.39584e-32,0.79961,-502.652,-204.518)">
        <path class="line1" d="M634.087,300.805L673.361,261.53" fill="none"></path>
      </g>
      <g transform="matrix(-1.28587e-16,-0.79961,0.79961,-1.28587e-16,-204.752,543.031)">
        <path class="line2" d="M634.087,300.805L673.361,261.53"></path>
      </g>
    </svg>
  </div>
) : (type === "warning") ? (
  <div class="okp-svg-warning okp-animate-svg">
    <svg class="okp-circular">
      <circle
        class="path"
        cx="75"
        cy="75"
        r="50"
        fill="none"
        stroke-width="5"
        stroke-miterlimit="10"></circle>
    </svg>
    <svg class="okp-exclamation">
      <g transform="matrix(1,0,0,1,-615.516,-257.346)">
        <g transform="matrix(0.56541,-0.56541,0.56541,0.56541,93.7153,495.69)">
          <path class="line" d="M634.087,300.805L673.361,261.53" fill="none"></path>
        </g>
        <g transform="matrix(2.27612,-2.46519e-32,0,2.27612,-792.339,-404.147)">
          <circle class="dot" cx="621.52" cy="316.126" r="1.318"></circle>
        </g>
      </g>
    </svg>
  </div>
) : null}
