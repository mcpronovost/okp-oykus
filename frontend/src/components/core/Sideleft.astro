---
import type { Lang } from "@/types/i18n.types";
import OkpSideleftPanel from "./react/SideleftPanel.jsx";

interface Props {
  lang: Lang;
}

const { slug } = Astro.params;
const { lang }: Props = Astro.props;

const webSideleftOpen = Astro.cookies.get("okp-web-sideleftOpen");
---

<OkpSideleftPanel lang={lang} slug={slug} open={webSideleftOpen?.boolean()} client:idle />
