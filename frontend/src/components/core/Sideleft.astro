---
import type { User } from "@/types/auth.types";
import type { Lang } from "@/types/i18n.types";
import OkpSideleftPanel from "./react/SideleftPanel.jsx";

interface Props {
  lang: Lang;
  user: User | null;
}

const { slug } = Astro.params;
const { lang, user }: Props = Astro.props;

const webSideleftOpen = Astro.cookies.get("okp-web-sideleftOpen");
---

<OkpSideleftPanel lang={lang} user={user} slug={slug} open={webSideleftOpen?.boolean()} client:idle />
